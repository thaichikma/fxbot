# MT5 Credentials
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=FTMO-Demo
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# News API (Finnhub) — economic calendar may require paid tier; if 403, set news.calendar_enabled: false in settings.yaml
FINNHUB_API_KEY=your_finnhub_key

# Environment (production VPS: ENV=production — xem docs/deployment.md)
ENV=development
